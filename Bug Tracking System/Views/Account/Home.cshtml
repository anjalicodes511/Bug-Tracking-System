@{
    ViewBag.Title = "Home";
}

<style>
    body {
        background: linear-gradient(135deg, #4e73df, #1cc88a);
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    .navbar-custom {
/*        background: rgba(255,255,255,0.1);*/
        backdrop-filter: blur(15px);
    }

    .navbar-brand {
        font-weight: bold;
        color: white !important;
    }

    .main-container {
        padding: 40px 20px;
    }

    .dashboard-card {
        background: white;
        border-radius: 20px;
        padding: 25px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.15);
        transition: all 0.3s ease;
    }

        .dashboard-card:hover {
            transform: translateY(-6px);
        }

    .welcome-box {
        text-align: center;
        margin-bottom: 30px;
    }

    .welcome-title {
        font-size: 28px;
        font-weight: 600;
        color: white;
    }

    .welcome-sub {
        color: rgba(255,255,255,0.8);
    }

    .stat-card {
        border-radius: 15px;
        padding: 20px;
        color: white;
    }

    .bg-primary-soft {
        background: #4e73df;
    }

    .bg-success-soft {
        background: #1cc88a;
    }

    .bg-warning-soft {
        background: #f6c23e;
    }

    .stat-number {
        font-size: 24px;
        font-weight: bold;
    }

    .action-btn {
        border-radius: 25px;
        padding: 10px 20px;
        margin: 5px;
    }
</style>

<!-- Navbar -->
<nav class="navbar navbar-expand-lg navbar-custom">
    <div class="container">
        <span class="navbar-brand">
            🐞 Bug Tracker
        </span>

        <div class="ml-auto">
            <a href="@Url.Action("Logout","Account")" class="btn btn-outline-light btn-sm">
                Logout
            </a>
        </div>
    </div>
</nav>

<div class="container main-container">

    <!-- Welcome Section -->
    <div class="welcome-box">
        <div class="welcome-title">
            Welcome, @User.Identity.Name 👋
        </div>
        <div class="welcome-sub">
            Here's what's happening with your projects today
        </div>
    </div>

    <!-- Stats -->
    <div class="row mb-4">
        <div class="col-md-4">
            <div class="stat-card bg-primary-soft">
                <div>Total Bugs</div>
                <div class="stat-number">24</div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="stat-card bg-warning-soft">
                <div>Open Issues</div>
                <div class="stat-number">10</div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="stat-card bg-success-soft">
                <div>Resolved</div>
                <div class="stat-number">14</div>
            </div>
        </div>
    </div>

    <!-- Actions -->
    <div class="dashboard-card text-center">
        <h5 class="mb-3">Quick Actions</h5>

        <a href="#" class="btn btn-primary action-btn">
            ➕ Create Bug
        </a>

        <a href="#" class="btn btn-success action-btn">
            📋 View Bugs
        </a>

        <a href="#" class="btn btn-warning action-btn">
            ⚙ Manage Projects
        </a>
    </div>

    <!-- Extra Section -->
    <div class="dashboard-card mt-4">
        <h5>💡 Tip of the Day</h5>
        <p class="text-muted">
            Keep bug descriptions clear and reproducible to speed up debugging!
        </p>
    </div>

</div>