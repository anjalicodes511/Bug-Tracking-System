@{
    ViewBag.Title = "Login";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-4">

            <div class="card shadow">
                <div class="card-header text-center">
                    <h3>Login</h3>
                </div>

                <div class="card-body">

                    @using (Html.BeginForm("Login", "Account", FormMethod.Post,new {id = "loginForm" }))
                    {
                        @Html.AntiForgeryToken()
                        <div id="errorMsg" class="text-center bg-danger text-primary"></div>
                        <div class="mb-3">
                            @Html.Label("Email", new { @class = "form-label" })
                            @Html.TextBox("Email", null, new { @class = "form-control", placeholder = "abc@xyz.com", id = "emailId" })
                        </div>

                        <div class="mb-3">
                            @Html.Label("Password", new { @class = "form-label" })
                            @Html.Password("Password", null, new { @class = "form-control", id = "passwordId" })
                        </div>
                        <div class="mb-3 text-end">
                            @Html.ActionLink("Forgot Password?", "ForgotPassword", "Account", null, new { @class = "text-decoration-none" })
                        </div>
                        <div class="d-grid">
                            <input type="submit" value="Login" class="btn btn-login" />
                        </div>
                    }

                </div>
            </div>

        </div>
    </div>
</div>