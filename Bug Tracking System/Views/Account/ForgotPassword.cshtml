@{
    ViewBag.Title = "Forgot Password";
}
<div class="auth-wrapper">

    <div class="card auth-card shadow-lg p-5">

        <div class="text-center mb-4">

            <div class="auth-icon mb-3">
                <i class="fa-solid fa-lock"></i>
            </div>

            <h3 class="fw-bold mb-1">Forgot Password</h3>

            <p class="text-muted small">
                Enter your email and we'll send you an OTP
            </p>

        </div>

        <div class="mb-4 auth-field">

            <label class="form-label fw-semibold auth-label">
                Email Address
            </label>

            <div class="input-group auth-input-group">

                <span class="input-group-text auth-input-icon">
                    <i class="fa-solid fa-envelope"></i>
                </span>

                @Html.TextBox(
                    "Email",
                    null,
                    new
                    {
                        @class = "form-control auth-input",
                        id = "email",
                        placeholder = "Enter your email"
                    })

            </div>

        </div>

        <button class="btn btn-primary auth-btn w-100" id="sendOtpBtn">
            <i class="fa-solid fa-paper-plane me-2"></i>
            Send OTP
        </button>

        <div id="otpSection" class="mt-4"></div>

        <div class="text-center mt-4 small">
            <a href="/Account/Login" class="auth-link">
                ← Back to Login
            </a>
        </div>

    </div>

</div>