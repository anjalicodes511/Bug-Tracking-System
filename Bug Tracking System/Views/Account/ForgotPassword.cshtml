@{
    ViewBag.Title = "Forgot Password";
}

<div class="auth-wrapper">

    <div class="card auth-card shadow-lg p-5">

        <div class="text-center mb-4">

            <div class="auth-icon mb-3">
                <i class="fa-solid fa-key"></i>
            </div>

            <h3 class="fw-bold mb-1">Forgot Password</h3>

            <p class="text-muted small">
                Enter your email to receive OTP
            </p>

        </div>

        @using (Html.BeginForm("", "", FormMethod.Post, new { id = "forgotPasswordForm" }))
        {
            <div class="mb-3">

                <label class="form-label fw-semibold">Email</label>

                <div class="input-group">

                    <span class="input-group-text">
                        <i class="fa-solid fa-envelope"></i>
                    </span>

                    @Html.TextBox("Email", null,
                    new
                         {
                        @class = "form-control",
                        placeholder = "Enter your email",
                        id = "emailId"
                    })

                </div>

            </div>

            <button type="submit" class="btn btn-primary auth-btn w-100">
                <i class="fa-solid fa-paper-plane me-2"></i>
                Send OTP
            </button>
        }

        <div class="text-center mt-4 small">

            Remember your password?
            @Html.ActionLink("Login", "Login", "Account", null,
            new { @class = "text-decoration-none" })

        </div>

    </div>

</div>

@section Scripts{
    <script src="~/Scripts/Account/forgotPassword.js"></script>
}