@{
    ViewBag.Title = "Verify OTP";
}

<div class="container d-flex justify-content-center align-items-center" style="min-height:80vh;">

    <div class="col-md-4">

        <div class="card shadow-sm border-0">

            <div class="card-body p-4">

                <div class="text-center mb-4">
                    <h3 class="fw-bold text-primary">Email Verification</h3>
                    <p class="text-muted small">
                        Enter the OTP sent to your email
                    </p>
                </div>

                @using (Html.BeginForm("VerifyOtp", "Account", FormMethod.Post, new { id = "otpForm" }))
                {
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label for="otpId" class="form-label fw-semibold">
                            One Time Password
                        </label>

                        @Html.TextBox("Otp", null, new
                        {
                            @class = "form-control text-center",
                            placeholder = "Enter 6-digit OTP",
                            id = "otpId",
                            maxlength = "6",
                            autocomplete = "one-time-code"
                        })
                    </div>

                    <div class="d-grid mt-3">
                        <button type="submit" class="btn btn-signup">
                            Verify OTP
                        </button>
                    </div>

                    <div class="text-center mt-4 small">

                        <span class="text-muted">Didn't receive OTP?</span>
                        <br />

                        <!-- Timer text -->
                        <span id="resendTimer" class="text-muted">
                            Resend OTP in <span id="timer">60</span> seconds
                        </span>

                        <br />

                        <!-- Resend link -->
                        @Html.ActionLink(
                            "Resend OTP",
                            "ResendOtp",
                            "Account",
                            null,
                            new
                                 {
                                @class = "text-decoration-none fw-semibold",
                                id = "resendBtn",
                                style = "display:none;"
                            }
                        )
                    </div>
                }

            </div>

        </div>

    </div>

</div>

@section Scripts{
    <script src="~/Scripts/Account/verifyOtp.js"></script>
}